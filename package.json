{
  "name": "conflux",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, collaborative document editor with offline sync, deterministic CRDT conflict resolution, and granular version history",
  "scripts": {
    "dev": "tsx watch --clear-screen=false server.ts",
    "build": "prisma generate && next build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "start:migrate": "prisma migrate deploy && npm start",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.76",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "@tiptap/extension-collaboration": "^3.27.1",
    "@tiptap/extension-collaboration-caret": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "ai": "^5.0.206",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "lib0": "^0.2.117",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "^4.19.2",
    "ws": "^8.21.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "fast-check": "^3.23.1",
    "jest": "^29.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
