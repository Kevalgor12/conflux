# ---- Database (PostgreSQL) ----
# Pooled URL the app uses at runtime
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conflux?schema=public"
# Direct URL for migrations (optional; defaults to DATABASE_URL)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/conflux?schema=public"

# ---- Auth (Auth.js / NextAuth v5) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# OAuth providers (optional)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ---- Realtime ----
# WSS origin the browser connects to (the app's own host)
NEXT_PUBLIC_WS_URL="ws://localhost:3000"
# Max bytes accepted per WebSocket message (OOM guard)
WS_MAX_PAYLOAD="262144"
# Extra allowed WebSocket Origins (comma-separated). Same-origin is always allowed;
# set this only if the browser origin differs from the server host (CSWSH guard).
WS_ALLOWED_ORIGINS=""

# ---- AI (Vercel AI SDK + Google Gemini) ----
# Server-only; never exposed to the client bundle
GOOGLE_GENERATIVE_AI_API_KEY=""
# Optional model overrides (confirm exact ids against the current Google AI catalog)
GEMINI_FLASH_MODEL="gemini-2.0-flash"
GEMINI_PRO_MODEL="gemini-2.5-pro"
# Set to "true" (and provide the key above) to surface AI features in the UI
NEXT_PUBLIC_AI_ENABLED="false"

# ---- App ----
PORT="3000"
NODE_ENV="development"
